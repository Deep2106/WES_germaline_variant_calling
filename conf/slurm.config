/*
========================================================================================
    SLURM PROFILE CONFIGURATION
========================================================================================
    HPC-specific settings for Slurm execution
    Optimized for production WES/WGS workloads
----------------------------------------------------------------------------------------
*/

/*
========================================================================================
    EXECUTOR SETTINGS
========================================================================================
*/

executor {
    name = 'slurm'
    
    // Queue management
    queueSize = 200
    submitRateLimit = '30/1min'
    pollInterval = '20 sec'
    exitReadTimeout = '5 min'
}

/*
========================================================================================
    PROCESS SETTINGS
========================================================================================
*/

process {
    
    // Default Slurm settings
    executor = 'slurm'
    queue = 'ProdQ'
   // clusterOptions = '--exclude=prdubrcn093,prdubrcn094'    # its working now   
    // Error handling for common Slurm exit codes
    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139, 140, 247] ? 'retry' : 'finish' }
    maxRetries = 2
    
    // Don't use Nextflow scratch staging - RCSI HPC prologue sets up TMPDIR as mentioned in william's document.
    scratch = false
    
    // Minimal beforeScript - RCSI prologue already sets TMPDIR to /local/scratch/<jobid>
    beforeScript = """
        echo "Job ID: \${SLURM_JOB_ID}, TMPDIR: \${TMPDIR:-not set}"
        if [ -n "\${TMPDIR:-}" ] && [ -d "\${TMPDIR}" ]; then
            export _JAVA_OPTIONS="-Djava.io.tmpdir=\$TMPDIR"
        fi
    """
}

/*
========================================================================================
    SINGULARITY SETTINGS FOR SLURM
========================================================================================
*/

singularity {
    enabled = true
    autoMounts = true
    
    // Bind /home/data so containers can access FASTQ files and references, if data in /home/sdata then update this line. === DEEP ==
    runOptions = '-B /home/data -B /local/scratch -B /home/sdata'
}
