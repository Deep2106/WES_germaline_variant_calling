/*
========================================================================================
    WES/WGS GERMLINE VARIANT CALLING PIPELINE v2.0
========================================================================================
    Production pipeline configuration
----------------------------------------------------------------------------------------
*/

params {
    
    // =========================================================================
    // INPUT/OUTPUT
    // =========================================================================
    input                       = null
    outdir                      = './results'
    
    // =========================================================================
    // REFERENCE GENOME
    // =========================================================================
    genome                      = 'GRCh38'
    fasta                       = null
    fasta_fai                   = null
    fasta_dict                  = null
    bwa_index                   = null
    
    // =========================================================================
    // KNOWN SITES (BQSR)
    // =========================================================================
    dbsnp                       = null
    dbsnp_tbi                   = null
    known_indels                = null
    known_indels_tbi            = null
    
    // =========================================================================
    // TARGET REGIONS (WES)
    // =========================================================================
    targets_bed                 = null
    
    // =========================================================================
    // GENOMICSDB - INCREMENTAL JOINT CALLING
    // Auto-detection: if path exists AND master.ped exists -> UPDATE
    // =========================================================================
    genomicsdb_path             = null
    genomicsdb_update           = false
    
    // =========================================================================
    // PED FILE MANAGEMENT
    // =========================================================================
    master_ped                  = null
    
    // =========================================================================
    // VARIANT CALLERS
    // =========================================================================
    run_deepvariant             = false     // OFF by default
    deepvariant_model           = 'WES'
    
    // =========================================================================
    // OPTIONAL ANALYSES
    // =========================================================================
    run_peddy                   = true
    
    // =========================================================================
    // QC AND TRIMMING
    // =========================================================================
    skip_fastp                  = false
    skip_fastqc                 = false
    fastp_qualified_quality     = 20
    fastp_length_required       = 50
    multiqc_config              = null
    
    // =========================================================================
    // READ GROUP PARAMETERS
    // =========================================================================
    library_id                  = 'RCSI'
    platform                    = 'Illumina'
    platform_unit               = 'Unknown'
    remove_duplicates           = true
    
    // =========================================================================
    // VARIANT FILTERING
    // =========================================================================
    snp_filter_qd               = 2.0
    snp_filter_fs               = 60.0
    snp_filter_mq               = 40.0
    snp_filter_sor              = 3.0
    snp_filter_mqranksum        = -12.5
    snp_filter_readposranksum   = -8.0
    indel_filter_qd             = 2.0
    indel_filter_fs             = 200.0
    indel_filter_sor            = 10.0
    
    // =========================================================================
    // ANNOVAR CONFIGURATION (13 protocols)
    // =========================================================================
    annovar_db                  = null
    annovar_buildver            = 'hg38'
    annovar_protocol            = 'refGene,cytoBand,genomicSuperDups,exac03,gnomad41_exome,gnomad41_genome,avsnp151,dbnsfp47a,dbscsnv11,mcap,clinvar_20250721,revel,gene4denovo201907'
    annovar_operation           = 'g,r,r,f,f,f,f,f,f,f,f,f,f'
    annovar_argument            = "'-splicing 5',,,,,,,,,,,,"
    
    // =========================================================================
    // RESOURCE LIMITS
    // =========================================================================
    max_cpus                    = 30
    max_memory                  = 350.GB
    max_time                    = 168.h
    
    // =========================================================================
    // PER-TOOL CPU ALLOCATION
    // =========================================================================
    fastqc_cpus                 = 2
    fastp_cpus                  = 4
    bwa_cpus                    = 10
    markdup_cpus                = 4
    bqsr_cpus                   = 4
    mosdepth_cpus               = 4
    haplotypecaller_cpus        = 8
    deepvariant_cpus            = 10
    genomicsdbimport_cpus       = 8
    genotypegvcfs_cpus          = 8
    annovar_cpus                = 4
    glnexus_cpus                = 8
    
    // =========================================================================
    // PER-TOOL MEMORY ALLOCATION
    // =========================================================================
    fastqc_memory               = 4.GB
    fastp_memory                = 8.GB
    bwa_memory                  = 64.GB
    markdup_memory              = 24.GB
    bqsr_memory                 = 16.GB
    mosdepth_memory             = 8.GB
    haplotypecaller_memory      = 32.GB
    deepvariant_memory          = 64.GB
    genomicsdbimport_memory     = 64.GB
    genotypegvcfs_memory        = 64.GB
    annovar_memory              = 16.GB
    glnexus_memory              = 64.GB
    
    // =========================================================================
    // STORAGE CONFIGURATION
    // =========================================================================
    scratch_dir                 = '/local/scratch'
    
    // =========================================================================
    // SLURM CONFIGURATION
    // =========================================================================
    slurm_account               = null
    slurm_partition             = 'ProdQ'
    slurm_queue_size            = 200
    
    // =========================================================================
    // PIPELINE OPTIONS
    // =========================================================================
    help                        = false
    publish_dir_mode            = 'copy'
}

// Container paths
params.singularity_image_dir = '/home/data/human_genetics/ONE4ALL/Docker_Images'

params.containers = [
    fastqc:       "${params.singularity_image_dir}/fastqc_0.12.1.sif",
    fastp:        "${params.singularity_image_dir}/fastp_0.23.4.sif",
    bwamem2:      "${params.singularity_image_dir}/bwa-mem2-samtool2.3.1_1.22.1.sif",
    samtools:     "${params.singularity_image_dir}/samtools_1.23.sif",
    gatk4:        "${params.singularity_image_dir}/gatk4_4.6.2.0.sif",
    deepvariant:  "${params.singularity_image_dir}/deepvariant_1.9.0.sif",
    glnexus:      "${params.singularity_image_dir}/glnexus_1.2.7.sif",
    bcftools:     "${params.singularity_image_dir}/bcftool_1.23.sif",
    mosdepth:     "${params.singularity_image_dir}/mosdepth_0.3.11.sif",
    multiqc:      "${params.singularity_image_dir}/multiqc_1.33.sif",
    peddy:        "${params.singularity_image_dir}/peddy_0.4.8.sif",
    annovar:      "${params.singularity_image_dir}/annovar_2020Jun08.sif",
    python:       "${params.singularity_image_dir}/python_3.14.2.sif"
]

profiles {
    slurm {
        process.executor = 'slurm'
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = "${HOME}/.singularity/cache"
        docker.enabled = false
        workDir = "${params.scratch_dir}/${System.getenv('USER')}/nextflow_work"
        includeConfig 'conf/slurm.config'
    }
    
    local {
        process.executor = 'local'
        singularity.enabled = true
        singularity.autoMounts = true
        docker.enabled = false
        includeConfig 'conf/local.config'
    }
    
    test {
        includeConfig 'conf/test.config'
    }
}

includeConfig 'conf/base.config'

timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
    fields = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,peak_rss,peak_vmem'
}

dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/dag.svg"
    overwrite = true
}

manifest {
    name            = 'wes-germline-pipeline'
    author          = 'Bioinformatics Team'
    description     = 'Production WES/WGS germline variant calling with incremental joint calling'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '2.0.0'
}

def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "WARNING: Invalid max_memory, using default: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "WARNING: Invalid max_time, using default: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj, params.max_cpus as int)
        } catch (all) {
            println "WARNING: Invalid max_cpus, using default: $obj"
            return obj
        }
    }
}

cleanup = true
