/*
========================================================================================
    GATK GENOMICSDBIMPORT MODULE
========================================================================================
    Import GVCFs into GenomicsDB for joint genotyping
    Supports both creating new database and updating existing one
    
    CRITICAL OPTIMIZATIONS:
    - Uses --merge-input-intervals true (Do NOT use --intervals in GenotypeGVCFs!)
    - Creates on LOCAL SCRATCH first to avoid NFS locking issues
    - Uses bcftools to extract sample names (more reliable than filename parsing)
    
    Input:
        gvcfs           - GVCF files
        gvcf_indices    - GVCF index files (.tbi)
        intervals       - Target intervals BED (for WES)
        existing_db     - Path to existing GenomicsDB (for update mode)
        update_db       - Boolean: true=update, false=create

    Output:
        genomicsdb      - Path to GenomicsDB
        versions        - Software versions
----------------------------------------------------------------------------------------
*/

process GATK_GENOMICSDBIMPORT {
    tag "genomicsdb_${update_db ? 'UPDATE' : 'CREATE'}"
    label 'process_high'
    container "${params.containers.gatk4}"
    
    publishDir "${params.outdir}/genomicsdb", mode: 'copy', pattern: "genomicsdb/**", enabled: false
    
    input:
    path gvcfs
    path gvcf_indices
    path intervals
    path existing_db
    val update_db
    
    output:
    path "genomicsdb", emit: genomicsdb
    path "versions.yml", emit: versions
    
    when:
    task.ext.when == null || task.ext.when
    
    script:
    def args = task.ext.args ?: ''
    
    // Calculate Java heap size (leave 8GB for overhead - GenomicsDB is memory intensive)
    def avail_mem = task.memory ? task.memory.toGiga() - 8 : 56
    def java_opts = "-Xmx${avail_mem}g -XX:+UseParallelGC -XX:ParallelGCThreads=4 -Djava.io.tmpdir=\$TMPDIR"
    
    // Intervals argument
    def intervals_arg = intervals.name != 'NO_FILE' ? "--intervals ${intervals}" : ""
    
    // Reader threads and parallel intervals
    def reader_threads = Math.max(1, task.cpus - 2)
    def parallel_intervals = Math.max(1, (task.cpus / 4).intValue())
    
    if (update_db && existing_db.name != 'NO_DB') {
        // UPDATE existing GenomicsDB
        """
        #!/bin/bash
        set -euo pipefail
        
        # =========================================================================
        # Set up LOCAL SSD scratch - GenomicsDB is very I/O intensive
        # =========================================================================
        if [ -n "\${SLURM_JOB_ID:-}" ] && [ -d "/local/scratch/\${SLURM_JOB_ID}" ]; then
            export TMPDIR="/local/scratch/\${SLURM_JOB_ID}"
            LOCAL_SCRATCH="/local/scratch/\${SLURM_JOB_ID}/gdb_update"
        elif [ -n "\${TMPDIR:-}" ] && [ -d "\${TMPDIR}" ]; then
            LOCAL_SCRATCH="\${TMPDIR}/gdb_update"
        else
            export TMPDIR=\$(mktemp -d)
            LOCAL_SCRATCH="\${TMPDIR}/gdb_update"
            trap "rm -rf \$TMPDIR" EXIT
        fi
        mkdir -p \${LOCAL_SCRATCH}
        
        echo "=============================================="
        echo "GENOMICSDB UPDATE MODE"
        echo "=============================================="
        echo "TMPDIR: \${TMPDIR}"
        echo "Local scratch: \${LOCAL_SCRATCH}"
        echo "Existing DB: ${existing_db}"
        
        # Generate timestamp for backup
        BACKUP_TIMESTAMP=\$(date +"%Y%m%d_%H%M%S")
        BACKUP_NAME="${existing_db}_backup_\${BACKUP_TIMESTAMP}"
        
        # Create backup of existing GenomicsDB before any modifications
        echo "Creating backup: \${BACKUP_NAME}"
        cp -r ${existing_db} \${BACKUP_NAME}
        echo "Backup created successfully"
        
        # Copy existing database to LOCAL SCRATCH for update (avoids NFS locking issues)
        LOCAL_GENOMICSDB="\${LOCAL_SCRATCH}/genomicsdb_temp"
        echo "Copying existing GenomicsDB to local scratch..."
        cp -r ${existing_db} \${LOCAL_GENOMICSDB}
        
        # Build sample map file using bcftools (more reliable than filename parsing)
        echo "Building sample map for new GVCFs..."
        > sample_map.txt
        for gvcf in *.g.vcf.gz; do
            if [ -f "\$gvcf" ]; then
                sample_name=\$(bcftools query -l \$gvcf | head -1)
                printf "%s\\t%s\\n" "\${sample_name}" "\$(readlink -f \$gvcf)" >> sample_map.txt
            fi
        done
        
        echo "Samples to add:"
        cat sample_map.txt
        echo "Sample count: \$(wc -l < sample_map.txt)"
        
        # Update GenomicsDB on local scratch
        gatk --java-options "${java_opts}" GenomicsDBImport \\
            --sample-name-map sample_map.txt \\
            --genomicsdb-update-workspace-path \${LOCAL_GENOMICSDB} \\
            ${intervals_arg} \\
            --tmp-dir \$TMPDIR \\
            --merge-input-intervals true \\
            --reader-threads ${reader_threads} \\
            --max-num-intervals-to-import-in-parallel ${parallel_intervals} \\
            --genomicsdb-shared-posixfs-optimizations true \\
            --bypass-feature-reader true \\
            --batch-size 50 \\
            ${args}
        
        echo "GenomicsDB update complete on local scratch"
        
        # Copy updated DB back to work directory
        echo "Copying updated GenomicsDB to work directory..."
        rm -rf genomicsdb 2>/dev/null || true
        cp -r \${LOCAL_GENOMICSDB} genomicsdb
        
        echo "=============================================="
        echo "UPDATE SUMMARY:"
        echo "  - Backup: \${BACKUP_NAME}"
        echo "  - Updated DB: genomicsdb"
        echo "=============================================="
        
        # Cleanup local temp
        rm -rf \${LOCAL_GENOMICSDB}
        
        cat <<-END_VERSIONS > versions.yml
        "${task.process}":
            gatk4: \$(gatk --version 2>&1 | head -n1 | sed 's/^.*(GATK) v//' | sed 's/ .*\$//')
            mode: "update"
            backup: "\${BACKUP_NAME}"
        END_VERSIONS
        """
    } else {
        // CREATE new GenomicsDB
        """
        #!/bin/bash
        set -euo pipefail
        
        # =========================================================================
        # Set up LOCAL SSD scratch - GenomicsDB is very I/O intensive
        # =========================================================================
        if [ -n "\${SLURM_JOB_ID:-}" ] && [ -d "/local/scratch/\${SLURM_JOB_ID}" ]; then
            export TMPDIR="/local/scratch/\${SLURM_JOB_ID}"
            LOCAL_SCRATCH="/local/scratch/\${SLURM_JOB_ID}/gdb_create"
        elif [ -n "\${TMPDIR:-}" ] && [ -d "\${TMPDIR}" ]; then
            LOCAL_SCRATCH="\${TMPDIR}/gdb_create"
        else
            export TMPDIR=\$(mktemp -d)
            LOCAL_SCRATCH="\${TMPDIR}/gdb_create"
            trap "rm -rf \$TMPDIR" EXIT
        fi
        mkdir -p \${LOCAL_SCRATCH}
        
        echo "=============================================="
        echo "GENOMICSDB CREATE MODE"
        echo "=============================================="
        echo "TMPDIR: \${TMPDIR}"
        echo "Local scratch: \${LOCAL_SCRATCH}"
        echo "Working directory: \$(pwd)"
        
        # Remove any existing genomicsdb directory from failed previous runs
        if [ -d "genomicsdb" ]; then
            echo "Removing existing genomicsdb directory from previous failed run..."
            rm -rf genomicsdb
        fi
        
        # Build sample map file using bcftools (more reliable than filename parsing)
        echo "Building sample map for new GenomicsDB..."
        > sample_map.txt
        for gvcf in *.g.vcf.gz; do
            if [ -f "\$gvcf" ]; then
                sample_name=\$(bcftools query -l \$gvcf | head -1)
                printf "%s\\t%s\\n" "\${sample_name}" "\$(readlink -f \$gvcf)" >> sample_map.txt
            fi
        done
        
        echo "Samples to import:"
        cat sample_map.txt
        echo "Sample count: \$(wc -l < sample_map.txt)"
        
        # Debug info
        echo "Available disk space:"
        df -h . \${TMPDIR} 2>/dev/null || true
        
        # Create GenomicsDB on LOCAL SCRATCH first (avoids NFS locking issues)
        LOCAL_GENOMICSDB="\${LOCAL_SCRATCH}/genomicsdb_temp"
        echo "Creating GenomicsDB on local scratch: \${LOCAL_GENOMICSDB}"
        
        gatk --java-options "${java_opts}" GenomicsDBImport \\
            --sample-name-map sample_map.txt \\
            --genomicsdb-workspace-path \${LOCAL_GENOMICSDB} \\
            ${intervals_arg} \\
            --tmp-dir \$TMPDIR \\
            --merge-input-intervals true \\
            --reader-threads ${reader_threads} \\
            --max-num-intervals-to-import-in-parallel ${parallel_intervals} \\
            --genomicsdb-shared-posixfs-optimizations true \\
            --bypass-feature-reader true \\
            --batch-size 50 \\
            ${args}
        
        echo "GenomicsDB creation complete on local scratch"
        
        # Copy from local scratch to work directory (NFS)
        echo "Copying GenomicsDB to work directory..."
        rm -rf genomicsdb 2>/dev/null || true
        cp -r \${LOCAL_GENOMICSDB} genomicsdb
        
        echo "GenomicsDB copy complete"
        
        # Cleanup local temp
        rm -rf \${LOCAL_GENOMICSDB}
        
        cat <<-END_VERSIONS > versions.yml
        "${task.process}":
            gatk4: \$(gatk --version 2>&1 | head -n1 | sed 's/^.*(GATK) v//' | sed 's/ .*\$//')
            mode: "create"
        END_VERSIONS
        """
    }
    
    stub:
    """
    mkdir -p genomicsdb
    touch genomicsdb/__tiledb_workspace.tdb
    
    cat <<-END_VERSIONS > versions.yml
    "${task.process}":
        gatk4: 4.6.1.0
        mode: "stub"
    END_VERSIONS
    """
}
